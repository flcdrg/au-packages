<!-- Do not remove this test for UTF-8: if “Ω” doesn’t appear as greek uppercase omega letter enclosed in quotation marks, you should use an editor that supports UTF-8, not this one. -->
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>mergiraf</id>
    <version>0.16.3</version>
    <packageSourceUrl>https://github.com/flcdrg/au-packages/tree/master/mergiraf</packageSourceUrl>
    <owners>flcdrg</owners>
    <title>Mergiraf</title>
    <authors>Merigraf developers</authors>
    <projectUrl>https://mergiraf.org</projectUrl>
    <iconUrl>https://cdn.jsdelivr.net/gh/flcdrg/au-packages@master/mergiraf/icons/mergiraf.png</iconUrl>
    <projectSourceUrl>https://codeberg.org/mergiraf/mergiraf/</projectSourceUrl>
    <docsUrl>https://mergiraf.org/introduction.html</docsUrl>
    <bugTrackerUrl>https://codeberg.org/mergiraf/mergiraf/issues</bugTrackerUrl>
    <tags>mergiraf git conflict</tags>
    <summary>A syntax-aware git merge driver for a growing collection of programming languages and file formats.</summary>
    <description>Mergiraf can solve a wide range of Git merge conflicts. That's because it's aware of the trees in your files! Thanks to its understanding of your language, it can often reconcile the needs of both sides.

You can teach Mergiraf a new language in a completely declarative way. It's a nonviolent animal, so it prefers that over imperatives</description>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
